# render scripts — local dev tools only, never deploy
*-render.py
*-render-v*.py
render_*.py
group*-render.py

# backup files — use _archive/ for tracked backups
*.bak
*.bak_*

# generated output (large binaries)
memory_cards/
reels/*.mp4
reels/*.png

# Python cache
__pycache__/
*.pyc
*.pyo
.env

# local Codex worktrees
.worktrees/
