      <span class="x" onclick="closeDrawer()">✕</span>
    </div>
    <div class="dr-body">
      <span class="dr-eyebrow">ARTICLE · 高頻 ★★★★★</span>
      <div class="dr-title">
        <span class="n">13</span>
        <span class="tt">記帳士業務</span>
      </div>
      <div class="dr-actions">
        <button class="dr-chip"><span class="ic">☆</span>收藏</button>
        <button class="dr-chip"><span class="ic">○</span>已熟記</button>
        <button class="dr-chip"><span class="ic">⊙</span>待複習</button>
      </div>
      <div class="dr-text">
        <p style="color:rgba(31,56,72,.75)">記帳士得在<span class="hl">登錄區域內</span>，執行下列業務：</p>
        <p><span class="ro">一、</span>受委任辦理營業、變更、註銷、停業、復業及其他登記事項。</p>
        <p><span class="ro">二、</span>受委任辦理各項<span class="hl">稅捐稽徵</span>案件之申報及申請事項。</p>
        <p><span class="ro">三、</span>受理稅務諮詢事項。</p>
        <p><span class="ro">四、</span>受委任辦理商業會計事務。</p>
        <p><span class="ro">五、</span>其他經主管機關核可辦理與記帳及報稅事務有關之事項。</p>
        <div class="but">前項業務<b>不包括</b>受委任辦理各項稅捐之查核簽證申報及訴願、行政訴訟事項。</div>
      </div>

      <!-- accordion 詳解 -->
      <div class="dr-acc">
        <div class="acc-item open" onclick="this.classList.toggle('open')">
          <div class="acc-head"><span class="cv">▸</span><span class="num">1</span><span class="ttl">章節標題與戰略權重</span></div>
          <div class="acc-body"><div class="acc-inner">
            <p>本條位於<b>第三章「業務及責任」</b>，是定義「記帳士能做什麼」的核心條文。</p>
            <p>近 10 年國考<b>命中率 92%</b>，<span class="kw">五款業務範圍</span>與<span class="kw">但書排除事項</span>幾乎每年都會考。建議：能背就背，不能背也要記住「五款 + 但書」的結構。</p>
          </div></div>
        </div>
        <div class="acc-item" onclick="this.classList.toggle('open')">
          <div class="acc-head"><span class="cv">▸</span><span class="num">2</span><span class="ttl">規範意旨與條文解析</span></div>
          <div class="acc-body"><div class="acc-inner">
            <p>本條規範記帳士的<b>業務範圍與限制</b>。前段五款採「列舉式」，原則上記帳士不得超出此範圍執業。</p>
            <p>「<span class="kw">登錄區域內</span>」為地域限制——須於登錄之直轄市、縣（市）內執行；跨區須申請。</p>
            <p>但書排除<b>查核簽證</b>（屬會計師專屬）、<b>訴願與行政訴訟</b>（屬律師專屬）。</p>
          </div></div>
        </div>
        <div class="acc-item" onclick="this.classList.toggle('open')">
          <div class="acc-head"><span class="cv">▸</span><span class="num">3</span><span class="ttl">執業要點與考情提示</span></div>
          <div class="acc-body"><div class="acc-inner">
            <p>考點集中在三處：<br/>① 五款業務的<b>順序與內容</b>是否能完整列出。<br/>② 但書的<b>三項排除事項</b>——查核簽證、訴願、行政訴訟。<br/>③ 與第 9 條（登錄）、第 14 條（限制）的<b>連動關係</b>。</p>
          </div></div>
        </div>
        <div class="acc-item" onclick="this.classList.toggle('open')">
          <div class="acc-head"><span class="cv">▸</span><span class="num">4</span><span class="ttl">核心摘要與記憶策略</span></div>
          <div class="acc-body"><div class="acc-inner">
            <p>口訣：<span class="kw">登 / 稅 / 諮 / 商 / 其他</span> + 但書「<span class="kw">不查不訴</span>」。</p>
            <p>登＝登記事項　稅＝稅捐稽徵　諮＝稅務諮詢　商＝商業會計　其他＝主管機關核可。<br/>不查＝不能查核簽證　不訴＝不能訴願 / 行政訴訟。</p>
          </div></div>
        </div>
        <div class="acc-item" onclick="this.classList.toggle('open')">
          <div class="acc-head"><span class="cv">▸</span><span class="num">5</span><span class="ttl">修法與聯覺備註</span></div>
          <div class="acc-body"><div class="acc-inner">
            <p>最近一次修正：<b>2019 / 06 / 21</b>（小幅文字修正）。實質規範自 2004 年立法以來未變動。</p>
            <p class="acc-empty">— 暫無進一步聯覺備註 —</p>
          </div></div>
        </div>
        <div class="acc-item" onclick="this.classList.toggle('open')">
          <div class="acc-head"><span class="cv">▸</span><span class="num">7</span><span class="ttl">相關法規及注意事項</span></div>
          <div class="acc-body"><div class="acc-inner">
            <p><b>同法</b>：§9 登錄、§14 業務限制、§15 廣告限制。</p>
            <p><b>跨法</b>：會計師法 §39（查核簽證）、行政訴訟法 §49（律師代理）。</p>
          </div></div>
        </div>
      </div>
    </div>
    <div class="dr-foot">
      <button class="dr-btn pri">✓ 已熟記</button>
      <button class="dr-btn sec">加入再讀清單</button>
      <button class="dr-btn peach">★ 收藏</button>
    </div>
  </aside>

<script>
const API = 'https://sofa-engine-api.onrender.com';

// ── 格式化日期 ─────────────────────────────
function fmtDate(iso){
  if(!iso) return '—';
  const d = new Date(iso);
  return d.getFullYear() + '.' +
    String(d.getMonth()+1).padStart(2,'0') + '.' +
    String(d.getDate()).padStart(2,'0');
}
function daysLeft(iso){
  if(!iso) return null;
  const diff = Math.ceil((new Date(iso) - Date.now()) / 86400000);
  return diff;
}

// ── 填充會員卡 ────────────────────────────
async function loadMember(){
  try {
    const res = await fetch(`${API}/api/me/progress`, { credentials:'include' });
    if(!res.ok) throw new Error('not_auth');
    const d = await res.json();

    // plan tag
    const planEl = document.getElementById('mc-plan');
    const planMap = { monthly:'月費方案', quarterly:'季費方案', trial:'試用序號', lifetime:'買斷終身' };
    planEl.textContent = planMap[d.plan] || d.plan || '月費方案';

    // status
    const days = daysLeft(d.expires_at);
    const statusEl = document.getElementById('mc-status');
    if(days !== null && days < 0){
      statusEl.textContent = 'EXPIRED';
      statusEl.style.color = 'rgba(245,240,234,.4)';
    } else {
      statusEl.textContent = 'ACTIVE';
    }

    // stats
    document.getElementById('mc-expires').textContent = fmtDate(d.expires_at);
    document.getElementById('mc-days-left').textContent = (days !== null && days >= 0) ? days + ' 天' : (days < 0 ? '已到期' : '—');
    document.getElementById('mc-activated').textContent = fmtDate(d.activated_at);

    // avatar：序號前兩字當字母
    const serial = d.serial || '';
    const short = serial.replace('SOFA-','').slice(0,4);
    document.getElementById('mc-avatar').textContent = short ? short[0] : 'S';
    document.getElementById('mc-serial-short').textContent = short || '——';

    // 付費紀錄表格
    renderPayTable([{
      serial: d.serial || '——',
      plan: planMap[d.plan] || d.plan || '—',
      activated: d.activated_at,
      expires: d.expires_at,
      active: (days !== null && days >= 0)
    }]);
  } catch(e) {
    // 未登入或 API 失敗：顯示佔位
    document.getElementById('pay-tbody').innerHTML =
      '<tr><td colspan="5" class="pay-empty">無法取得資料，請確認已登入。</td></tr>';
  }
}

function renderPayTable(rows){
  const tbody = document.getElementById('pay-tbody');
  if(!rows || !rows.length){
    tbody.innerHTML = '<tr><td colspan="5" class="pay-empty">尚無付費紀錄</td></tr>';
    return;
  }
  tbody.innerHTML = rows.map(r => `
    <tr>
      <td><span class="serial-mono">SOFA-${r.serial.replace('SOFA-','')}</span></td>
      <td><span class="plan-tag">${r.plan}</span></td>
      <td>${fmtDate(r.activated)}</td>
      <td>${fmtDate(r.expires)}</td>
      <td><span class="status-tag${r.active ? '' : ' status-expired'}">${r.active ? 'ACTIVE' : 'EXPIRED'}</span></td>
    </tr>`).join('');
}

loadMember();

// ── Drawer ────────────────────────────────
function openDrawer(){
  document.querySelector('.drawer').classList.add('open');
  document.querySelector('.drawer-mask').classList.add('open');
}
function closeDrawer(){
  document.querySelector('.drawer').classList.remove('open');
  document.querySelector('.drawer-mask').classList.remove('open');
}
// active nav on scroll
const navLinks = document.querySelectorAll('.nav-list a');
const sections = document.querySelectorAll('section.block');
const setActive = id => {
  navLinks.forEach(l => l.classList.toggle('on', l.getAttribute('href') === '#'+id));
};
const io = new IntersectionObserver((entries)=>{
  entries.forEach(e=>{
    if(e.isIntersecting) setActive(e.target.id);
  });
},{rootMargin:'-30% 0px -60% 0px'});
sections.forEach(s=>io.observe(s));
</script>
</body>
</html>
