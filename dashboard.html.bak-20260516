<!doctype html>
<html lang="zh-Hant">
<head>
<meta charset="utf-8" />
<title>SoFa Engine — 會員中心</title>
<meta name="viewport" content="width=device-width, initial-scale=1" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+TC:wght@400;500;600;700&family=Noto+Sans+TC:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
<style>
  :root{
    --navy:#1F3848;
    --navy-2:#19303E;
    --navy-3:#142836;
    --navy-4:#0D1C28;
    --plum-1:#2C4A5C;
    --plum-2:#4A6373;
    --peach:#E7BBA7;
    --peach-2:#F0CDBD;
    --peach-3:#C89580;
    --peach-dim:rgba(231,187,167,.7);
    --cream:#F5F0EA;
    --cream-2:#ECE5DB;
    --cream-3:#E0D6C7;
    --mauve:#B38BA7;
    --good:#9FB89F;
    --warn:#D9B084;
    --line:rgba(245,240,234,.10);
    --line-2:rgba(245,240,234,.18);
    --serif:"Noto Serif TC", "Songti TC", serif;
    --sans:"Noto Sans TC", system-ui, sans-serif;
    --mono:"JetBrains Mono", ui-monospace, monospace;
  }
  *{box-sizing:border-box;margin:0;padding:0}
  html,body{background:var(--navy-3)}
  body{
    font-family:var(--sans);
    color:var(--cream);
    font-size:15px;
    line-height:1.65;
    -webkit-font-smoothing:antialiased;
    text-rendering:optimizeLegibility;
  }
  a{color:inherit;text-decoration:none}
  button{font-family:inherit;cursor:pointer;border:none;background:none;color:inherit}
  input{font-family:inherit;color:inherit}
  ::selection{background:var(--peach);color:var(--navy)}

  /* === Top bar === */
  .topbar{
    background:var(--navy);
    border-bottom:1px solid var(--line);
    padding:18px 40px;
    display:flex;align-items:center;justify-content:space-between;
    position:sticky;top:0;z-index:50;
    background:rgba(31,56,72,.92);
    backdrop-filter:blur(12px);
  }
  .brand{
    font-family:var(--mono);font-weight:500;font-size:17px;
    letter-spacing:.16em;
    display:flex;align-items:center;gap:12px;
  }
  .brand .dot{
    width:8px;height:8px;background:var(--peach);border-radius:50%;
    box-shadow:0 0 0 4px rgba(231,187,167,.18);
  }
  .top-mid{
    display:flex;gap:32px;font-size:14px;
    font-family:var(--mono);letter-spacing:.06em;
    color:rgba(245,240,234,.55);
  }
  .top-mid a{padding:6px 2px;border-bottom:1px solid transparent;transition:.18s}
  .top-mid a:hover{color:var(--cream);border-color:var(--peach-dim)}
  .top-right{display:flex;align-items:center;gap:18px;font-size:14px}
  .user-pill{
    display:flex;align-items:center;gap:10px;
    font-family:var(--mono);font-size:13px;letter-spacing:.06em;
    color:var(--cream);
  }
  .user-pill .live{
    width:7px;height:7px;background:var(--good);border-radius:50%;
    box-shadow:0 0 0 3px rgba(159,184,159,.18);
  }
  .btn-out{
    border:1px solid var(--line-2);
    padding:8px 18px;border-radius:3px;
    font-family:var(--mono);font-size:12px;letter-spacing:.12em;
    color:rgba(245,240,234,.78);
    transition:.2s;
  }
  .btn-out:hover{background:rgba(245,240,234,.06);color:var(--cream);border-color:var(--cream)}

  /* mobile nav toggle (hidden on desktop) */
  .menu-btn{display:none;width:36px;height:36px;border:1px solid var(--line-2);border-radius:3px;align-items:center;justify-content:center}
  .menu-btn span{display:block;width:16px;height:1.5px;background:var(--cream);position:relative}
  .menu-btn span::before,.menu-btn span::after{content:"";position:absolute;left:0;width:16px;height:1.5px;background:var(--cream)}
  .menu-btn span::before{top:-5px}
  .menu-btn span::after{top:5px}

  /* === Layout === */
  .shell{
    display:grid;
    grid-template-columns:260px 1fr;
    gap:0;
    min-height:calc(100vh - 70px);
  }

  /* === Sidebar === */
  aside.side{
    background:var(--navy-2);
    border-right:1px solid var(--line);
    padding:36px 28px 48px;
    position:sticky;top:70px;
    height:calc(100vh - 70px);
    overflow-y:auto;
  }
  /* countdown */
  .countdown{
    padding:24px 22px;
    border:1px solid var(--line-2);
    border-radius:3px;
    background:
      radial-gradient(ellipse 200px 140px at 80% 0%, rgba(231,187,167,.10), transparent 70%),
      var(--navy);
    position:relative;
    overflow:hidden;
  }
  .countdown::before{
    content:"";position:absolute;left:0;top:0;width:3px;height:100%;
    background:linear-gradient(to bottom, var(--peach) 0%, transparent 70%);
  }
  .cd-lab{
    font-family:var(--mono);font-size:11px;
    letter-spacing:.18em;color:var(--peach);text-transform:uppercase;
  }
  .cd-num{
    font-family:var(--serif);font-weight:600;font-size:64px;
    color:var(--cream);line-height:1;margin-top:10px;
    letter-spacing:-.01em;
  }
  .cd-unit{
    font-family:var(--mono);font-size:13px;color:rgba(245,240,234,.6);
    margin-top:10px;letter-spacing:.06em;
  }
  .cd-unit b{color:var(--cream);font-weight:500}
  .cd-date{
    margin-top:18px;padding-top:14px;border-top:1px dashed var(--line-2);
    font-family:var(--mono);font-size:13px;color:var(--cream);
    letter-spacing:.04em;display:flex;justify-content:space-between;
  }
  .cd-date span:first-child{color:rgba(245,240,234,.55)}

  .nav-section{margin-top:34px}
  .nav-section .lab{
    font-family:var(--mono);font-size:11px;
    color:rgba(245,240,234,.4);
    letter-spacing:.22em;text-transform:uppercase;
    padding:0 4px 14px;
  }
  .nav-list{display:flex;flex-direction:column;gap:2px}
  .nav-list a{
    display:flex;align-items:center;gap:14px;
    padding:11px 14px;
    font-size:14.5px;
    color:rgba(245,240,234,.7);
    border-radius:3px;
    position:relative;
    transition:.18s;
  }
  .nav-list a .num{
    font-family:var(--mono);font-size:11px;color:rgba(245,240,234,.35);
    width:22px;
  }
  .nav-list a:hover{background:rgba(245,240,234,.04);color:var(--cream)}
  .nav-list a.on{
    background:rgba(231,187,167,.10);
    color:var(--cream);
  }
  .nav-list a.on::before{
    content:"";position:absolute;left:-28px;top:50%;transform:translateY(-50%);
    width:3px;height:18px;background:var(--peach);border-radius:0 2px 2px 0;
  }
  .nav-list a.on .num{color:var(--peach)}

  .side-foot{
    margin-top:36px;padding:18px;
    border:1px dashed var(--line-2);
    border-radius:3px;
    font-family:var(--mono);font-size:11px;
    color:rgba(245,240,234,.42);
    letter-spacing:.08em;line-height:1.7;
  }
  .side-foot b{color:var(--peach);font-weight:500}

  /* === Main === */
  main.main{
    padding:56px 64px 96px;
    background:var(--navy-3);
    position:relative;
    overflow:hidden;
  }
  main.main::before{
    content:"";position:absolute;inset:0;
    background-image:
      linear-gradient(rgba(245,240,234,.018) 1px, transparent 1px),
      linear-gradient(90deg, rgba(245,240,234,.018) 1px, transparent 1px);
    background-size:60px 60px;
    mask-image:radial-gradient(ellipse 60% 50% at 50% 0%, #000 30%, transparent 70%);
    pointer-events:none;
  }
  .main-inner{max-width:1140px;margin:0 auto;position:relative}

  /* hero greeting */
  .greet{
    display:flex;align-items:flex-end;justify-content:space-between;
    padding-bottom:36px;border-bottom:1px solid var(--line);
    margin-bottom:48px;gap:32px;
  }
  .greet h1{
    font-family:var(--serif);font-weight:600;font-size:42px;
    color:var(--cream);line-height:1.2;letter-spacing:.005em;
  }
  .greet h1 em{font-style:normal;color:var(--peach)}
  .greet .sub{
    margin-top:14px;font-size:15px;color:rgba(245,240,234,.6);
    max-width:520px;line-height:1.75;
  }
  .greet .now{
    text-align:right;
    font-family:var(--mono);font-size:12px;
    color:rgba(245,240,234,.5);
    letter-spacing:.12em;
  }
  .greet .now .t{
    font-family:var(--serif);font-size:32px;color:var(--cream);
    font-weight:500;display:block;margin-top:6px;letter-spacing:.02em;
  }
  .greet .now .l{margin-top:4px}

  /* sections */
  section.block{margin-bottom:64px;scroll-margin-top:90px}
  .sec-head{
    display:flex;align-items:flex-end;justify-content:space-between;
    margin-bottom:24px;gap:24px;
    padding-bottom:14px;border-bottom:1px solid var(--line);
  }
  .sec-head .l{display:flex;flex-direction:column;gap:8px}
  .sec-head .eb{
    font-family:var(--mono);font-size:11px;
    color:var(--peach);letter-spacing:.22em;text-transform:uppercase;
    display:flex;align-items:center;gap:10px;
  }
  .sec-head .eb::before{content:"";width:18px;height:1px;background:var(--peach)}
  .sec-head h2{
    font-family:var(--serif);font-weight:600;font-size:26px;
    letter-spacing:.005em;color:var(--cream);
  }
  .sec-head .r{
    font-family:var(--mono);font-size:12px;
    color:rgba(245,240,234,.5);letter-spacing:.06em;
  }
  .sec-head .r a{color:var(--peach);transition:.18s}
  .sec-head .r a:hover{color:var(--peach-2)}

  /* === 會員資訊 card === */
  .member-card{
    background:linear-gradient(135deg, var(--navy-2), var(--navy));
    border:1px solid var(--line-2);
    border-radius:4px;
    padding:36px;
    display:grid;grid-template-columns:1fr 240px;gap:32px;
    position:relative;overflow:hidden;
  }
  .member-card::after{
    content:"S";
    position:absolute;right:-30px;bottom:-80px;
    font-family:var(--serif);font-weight:600;font-size:380px;
    color:rgba(231,187,167,.04);line-height:1;
    pointer-events:none;letter-spacing:-.04em;
  }
  .mc-l{position:relative;z-index:2}
  .mc-tags{display:flex;align-items:center;gap:12px;flex-wrap:wrap}
  .mc-tag{
    font-family:var(--mono);font-size:12px;font-weight:600;
    padding:6px 14px;border-radius:2px;
    background:var(--peach);color:var(--navy);letter-spacing:.04em;
  }
  .mc-status{
    font-family:var(--mono);font-size:12px;
    color:var(--good);letter-spacing:.14em;
    display:flex;align-items:center;gap:8px;
  }
  .mc-status::before{
    content:"";width:6px;height:6px;background:var(--good);border-radius:50%;
    box-shadow:0 0 0 3px rgba(159,184,159,.2);
  }
  .mc-divider{
    margin:28px 0 24px;height:1px;
    background:linear-gradient(to right, var(--line-2), transparent);
  }
  .mc-stats{display:grid;grid-template-columns:1fr 1fr 1fr;gap:32px}
  .mc-stat .k{
    font-family:var(--mono);font-size:11px;
    color:rgba(245,240,234,.5);letter-spacing:.16em;text-transform:uppercase;
  }
  .mc-stat .v{
    font-family:var(--serif);font-weight:500;font-size:24px;
    color:var(--cream);margin-top:8px;letter-spacing:.01em;
  }
  .mc-stat .v.peach{color:var(--peach)}
  .mc-stat .v.good{color:var(--good)}
  .mc-r{
    display:flex;flex-direction:column;align-items:center;justify-content:center;
    border-left:1px solid var(--line-2);padding-left:32px;
    position:relative;z-index:2;
  }
  .avatar{
    width:96px;height:96px;border-radius:50%;
    background:linear-gradient(135deg, var(--peach), var(--peach-3));
    color:var(--navy);
    display:flex;align-items:center;justify-content:center;
    font-family:var(--serif);font-weight:600;font-size:42px;
    box-shadow:0 0 0 4px rgba(231,187,167,.15);
  }
  .avatar-name{
    margin-top:14px;font-family:var(--mono);font-size:13px;
    letter-spacing:.16em;color:var(--cream);
  }

  /* === 付費紀錄 === */
  .pay-block{
    margin-top:24px;
    background:var(--navy-2);
    border:1px solid var(--line);
    border-radius:4px;
    overflow:hidden;
  }
  .pay-block-head{
    display:flex;align-items:center;justify-content:space-between;
    padding:18px 28px;
    border-bottom:1px solid var(--line);
  }
  .pay-block-head .lab{
    font-family:var(--mono);font-size:11px;letter-spacing:.22em;
    color:var(--peach);text-transform:uppercase;
    display:flex;align-items:center;gap:10px;
  }
  .pay-block-head .lab::before{content:"";width:14px;height:1px;background:var(--peach)}
  .pay-block-head .hint{
    font-family:var(--mono);font-size:11px;
    color:rgba(245,240,234,.4);letter-spacing:.06em;
  }
  .pay-table{width:100%;border-collapse:collapse}
  .pay-table th{
    font-family:var(--mono);font-size:10px;letter-spacing:.18em;
    color:rgba(245,240,234,.4);text-transform:uppercase;
    padding:12px 28px;text-align:left;
    border-bottom:1px solid var(--line);
    font-weight:400;
  }
  .pay-table td{
    padding:16px 28px;font-size:14px;
    color:rgba(245,240,234,.82);
    border-bottom:1px solid rgba(245,240,234,.05);
    vertical-align:middle;
  }
  .pay-table tr:last-child td{border-bottom:none}
  .pay-table .plan-tag{
    font-family:var(--mono);font-size:11px;font-weight:600;
    padding:4px 10px;border-radius:2px;
    background:var(--peach);color:var(--navy);
    letter-spacing:.04em;
  }
  .pay-table .status-tag{
    font-family:var(--mono);font-size:11px;
    color:var(--good);letter-spacing:.12em;
    display:inline-flex;align-items:center;gap:6px;
  }
  .pay-table .status-tag::before{
    content:"";width:5px;height:5px;border-radius:50%;
    background:var(--good);box-shadow:0 0 0 2px rgba(159,184,159,.2);
  }
  .pay-table .status-expired{color:rgba(245,240,234,.35)}
  .pay-table .status-expired::before{background:rgba(245,240,234,.25);box-shadow:none}
  .pay-table .serial-mono{
    font-family:var(--mono);font-size:13px;
    color:rgba(245,240,234,.6);letter-spacing:.08em;
  }
  .pay-empty{
    padding:32px 28px;
    font-family:var(--mono);font-size:13px;
    color:rgba(245,240,234,.3);letter-spacing:.06em;
    text-align:center;
  }

  /* === 學習進度 === */
  .prog-card{
    background:var(--navy-2);
    border:1px solid var(--line);
    border-radius:4px;
    padding:36px;
  }
  .prog-stats{
    display:grid;grid-template-columns:repeat(4, 1fr);
    gap:0;
    padding-bottom:32px;border-bottom:1px solid var(--line);
  }
  .ps{padding:0 28px;border-right:1px solid var(--line);text-align:center}
  .ps:first-child{padding-left:0}
  .ps:last-child{border-right:none;padding-right:0}
  .ps .v{
    font-family:var(--serif);font-weight:600;font-size:54px;
    color:var(--peach);line-height:1;letter-spacing:-.01em;
  }
  .ps .k{
    margin-top:14px;font-family:var(--mono);font-size:11px;
    letter-spacing:.18em;color:rgba(245,240,234,.5);text-transform:uppercase;
  }

  .prog-list{margin-top:28px;display:flex;flex-direction:column;gap:14px}
  .prog-row{
    display:grid;grid-template-columns:160px 1fr 40px;gap:24px;
    align-items:center;
  }
  .prog-row .name{
    font-size:14px;color:var(--cream);font-weight:500;
  }
  .prog-bar{
    height:6px;background:rgba(245,240,234,.08);
    border-radius:100px;overflow:hidden;position:relative;
  }
  .prog-bar .fill{
    position:absolute;top:0;left:0;height:100%;
    background:linear-gradient(to right, var(--peach), var(--peach-2));
    border-radius:100px;
    transition:width .8s ease;
  }
  .prog-row .n{
    font-family:var(--mono);font-size:13px;color:var(--peach);
    text-align:right;
  }

  /* === 法條搜尋 === */
  .search-card{
    background:var(--navy-2);
    border:1px solid var(--line);
    border-radius:4px;
    padding:32px;
  }
  .search-row{display:grid;grid-template-columns:1.4fr 1fr 1fr;gap:14px;margin-bottom:18px}
  .field{
    background:var(--navy-3);
    border:1px solid var(--line-2);
    border-radius:3px;
    padding:14px 18px;
    display:flex;align-items:center;gap:12px;
    transition:.18s;
  }
  .field:focus-within{border-color:var(--peach);background:var(--navy)}
  .field .ic{
    width:16px;height:16px;color:rgba(245,240,234,.45);flex-shrink:0;
    font-family:var(--mono);font-size:14px;
  }
  .field input{
    background:transparent;border:none;outline:none;width:100%;
    font-size:14px;color:var(--cream);
  }
  .field input::placeholder{color:rgba(245,240,234,.4)}
  .select-field{
    background:var(--navy-3);
    border:1px solid var(--line-2);
    border-radius:3px;
    padding:14px 18px;
    font-size:14px;color:rgba(245,240,234,.7);
    display:flex;align-items:center;justify-content:space-between;
    cursor:pointer;transition:.18s;
  }
  .select-field:hover{border-color:var(--peach-dim);color:var(--cream)}
  .select-field .car{color:var(--peach);font-family:var(--mono);font-size:11px}

  .chip-row{display:flex;gap:8px;flex-wrap:wrap;margin-top:6px}
  .chip{
    padding:8px 16px;border-radius:100px;
    font-family:var(--mono);font-size:12px;letter-spacing:.04em;
    border:1px solid var(--line-2);
    background:transparent;color:rgba(245,240,234,.7);
    transition:.18s;
  }
  .chip:hover{border-color:var(--peach-dim);color:var(--cream)}
  .chip.on{background:var(--peach);color:var(--navy);border-color:var(--peach);font-weight:600}

  .results{
    margin-top:24px;display:flex;flex-direction:column;gap:8px;
    padding-top:20px;border-top:1px dashed var(--line);
  }
  .res-row{
    display:flex;align-items:center;justify-content:space-between;
    padding:14px 16px;border-radius:3px;
    transition:.18s;cursor:pointer;
    border:1px solid transparent;
  }
  .res-row:hover{background:rgba(245,240,234,.03);border-color:var(--line-2)}
  .res-l{display:flex;align-items:center;gap:14px;font-size:14px}
  .res-l .law{color:rgba(245,240,234,.55);font-family:var(--mono);font-size:12px;letter-spacing:.06em}
  .res-l .art{color:var(--cream);font-weight:500}
  .res-l .ttl{color:rgba(245,240,234,.7);font-size:13.5px;border-left:1px solid var(--line-2);padding-left:14px;margin-left:6px}
  .res-r{display:flex;align-items:center;gap:14px;color:var(--peach);font-size:14px}
  .star{color:var(--peach);font-size:16px;cursor:pointer}
  .star.off{color:rgba(245,240,234,.2)}

  /* === 我的收藏 / 已熟記 / 待複習 grids === */
  .card-grid{display:grid;grid-template-columns:repeat(3, 1fr);gap:14px}
  .li-card{
    background:var(--navy-2);
    border:1px solid var(--line);
    border-radius:4px;
    padding:22px 24px;
    transition:.2s;
    cursor:pointer;
    position:relative;
  }
  .li-card:hover{transform:translateY(-2px);border-color:var(--peach-dim);background:var(--plum-1)}
  .li-card .law{
    font-family:var(--mono);font-size:11px;color:var(--peach);
    letter-spacing:.16em;text-transform:uppercase;font-weight:600;
  }
  .li-card .art{
    font-family:var(--serif);font-weight:600;font-size:22px;
    color:var(--cream);margin-top:10px;
    display:flex;align-items:baseline;gap:8px;
  }
  .li-card .art .pipe{color:rgba(245,240,234,.3);font-weight:400}
  .li-card .art .sub{font-family:var(--sans);font-size:14px;color:rgba(245,240,234,.78);font-weight:400}
  .li-card .meta{
    margin-top:14px;padding-top:12px;border-top:1px dashed var(--line);
    display:flex;justify-content:space-between;align-items:center;
    font-family:var(--mono);font-size:11px;color:rgba(245,240,234,.5);
    letter-spacing:.06em;
  }
  .li-card .meta a{color:var(--peach)}
  .li-card .star{position:absolute;top:18px;right:18px}
  .li-card.warn .law{color:var(--warn)}
  .li-card.warn .meta b{color:var(--warn);font-weight:500}

  /* empty state */
  .empty{
    padding:48px 32px;text-align:center;
    background:var(--navy-2);
    border:1px dashed var(--line-2);
    border-radius:4px;
    color:rgba(245,240,234,.5);font-size:14px;
  }
  .empty .ic{
    font-family:var(--serif);font-size:42px;color:rgba(245,240,234,.18);
    display:block;margin-bottom:14px;line-height:1;
  }
  .empty b{color:var(--cream);font-weight:500}

  /* === 備考工具 === */
  .tool-grid{display:grid;grid-template-columns:repeat(4, 1fr);gap:14px}
  .tool{
    background:var(--navy-2);
    border:1px solid var(--line);
    border-radius:4px;
    padding:28px 24px;
    transition:.2s;cursor:pointer;
    position:relative;overflow:hidden;
    display:flex;flex-direction:column;gap:16px;
    min-height:172px;
  }
  .tool::before{
    content:"";position:absolute;top:0;left:0;width:100%;height:2px;
    background:var(--peach);transform:scaleX(0);transform-origin:left;transition:.3s;
  }
  .tool:hover{transform:translateY(-3px);background:var(--plum-1);border-color:var(--peach-dim)}
  .tool:hover::before{transform:scaleX(1)}
  .tool .code{
    font-family:var(--mono);font-weight:600;font-size:13px;
    color:var(--peach);letter-spacing:.22em;
  }
  .tool .name{
    font-family:var(--serif);font-weight:600;font-size:22px;
    color:var(--cream);letter-spacing:.01em;
  }
  .tool .desc{
    font-size:13px;color:rgba(245,240,234,.58);line-height:1.6;
  }
  .tool .arrow{
    margin-top:auto;font-family:var(--mono);font-size:12px;
    color:var(--peach);letter-spacing:.06em;
    display:flex;align-items:center;gap:6px;
    transition:gap .2s;
  }
  .tool:hover .arrow{gap:12px}

  /* === 法規目錄 === */
  .laws-head{
    display:flex;align-items:center;justify-content:space-between;
    margin-bottom:18px;
  }
  .laws-search{
    background:var(--navy-2);
    border:1px solid var(--line-2);
    border-radius:3px;
    padding:10px 14px;width:260px;
    display:flex;align-items:center;gap:10px;font-size:13px;
  }
  .laws-search input{background:transparent;border:none;outline:none;width:100%;color:var(--cream)}
  .laws-search input::placeholder{color:rgba(245,240,234,.4)}
  .laws-count{
    font-family:var(--mono);font-size:12px;color:rgba(245,240,234,.55);
    letter-spacing:.08em;
  }
  .laws-count b{color:var(--peach);font-weight:600}
  .laws-grid{display:grid;grid-template-columns:repeat(3, 1fr);gap:12px}
  .law-card{
    background:var(--navy-2);
    border:1px solid var(--line);
    border-radius:3px;
    padding:20px 22px;
    transition:.18s;cursor:pointer;
    position:relative;
  }
  .law-card:hover{background:var(--plum-1);border-color:var(--peach-dim);transform:translateX(2px)}
  .law-card .nm{
    font-family:var(--serif);font-weight:500;font-size:16px;
    color:var(--cream);line-height:1.4;
  }
  .law-card .ct{
    margin-top:10px;font-family:var(--mono);font-size:11px;
    color:rgba(245,240,234,.5);letter-spacing:.08em;
  }
  .law-card .ct b{color:var(--peach);font-weight:600}
  .law-card .badge{
    position:absolute;top:18px;right:18px;
    font-family:var(--mono);font-size:10px;color:var(--peach);
    background:rgba(231,187,167,.10);
    padding:3px 8px;border-radius:2px;letter-spacing:.08em;
  }

  /* === 最近查詢 === */
  .recent-list{
    background:var(--navy-2);
    border:1px solid var(--line);
    border-radius:4px;
    overflow:hidden;
  }
  .rec-row{
    display:flex;align-items:center;justify-content:space-between;
    padding:16px 24px;
    border-bottom:1px solid var(--line);
    cursor:pointer;transition:.18s;
  }
  .rec-row:last-child{border-bottom:none}
  .rec-row:hover{background:rgba(245,240,234,.025);padding-left:30px}
  .rec-l{display:flex;align-items:center;gap:18px}
  .rec-l .law{
    font-family:var(--mono);font-size:11px;letter-spacing:.12em;
    color:var(--peach);min-width:80px;
  }
  .rec-l .art{font-family:var(--serif);font-weight:500;font-size:16px;color:var(--cream)}
  .rec-l .ttl{
    font-size:13.5px;color:rgba(245,240,234,.6);
    border-left:1px solid var(--line);padding-left:18px;
  }
  .rec-row .date{
    font-family:var(--mono);font-size:12px;color:rgba(245,240,234,.45);
    letter-spacing:.06em;
  }

  /* === Article drawer (right panel) === */
  .drawer-mask{
    position:fixed;inset:0;background:rgba(13,28,40,.7);
    backdrop-filter:blur(4px);z-index:99;
    opacity:0;pointer-events:none;transition:.25s;
  }
  .drawer-mask.open{opacity:1;pointer-events:auto}
  .drawer{
    position:fixed;top:0;right:0;bottom:0;width:560px;max-width:100%;
    background:var(--cream);color:var(--navy);
    z-index:100;
    transform:translateX(100%);transition:transform .35s cubic-bezier(.4,0,.2,1);
    display:flex;flex-direction:column;
    box-shadow:-20px 0 60px rgba(0,0,0,.4);
  }
  .drawer.open{transform:translateX(0)}
  .dr-head{
    padding:20px 28px;
    background:var(--cream-2);
    border-bottom:1px solid var(--cream-3);
    display:flex;align-items:center;justify-content:space-between;
    font-family:var(--mono);font-size:12px;letter-spacing:.08em;color:var(--navy);
  }
  .dr-head .crumb{display:flex;align-items:center;gap:8px}
  .dr-head .x{font-size:18px;cursor:pointer;color:var(--navy)}
  .dr-body{flex:1;overflow-y:auto;padding:36px 36px 24px}
  .dr-eyebrow{
    font-family:var(--mono);font-size:11px;font-weight:600;
    color:var(--peach-3);letter-spacing:.18em;text-transform:uppercase;
  }
  .dr-title{
    font-family:var(--serif);font-weight:600;
    margin-top:10px;display:flex;align-items:baseline;gap:14px;
  }
  .dr-title .n{font-size:54px;letter-spacing:-.02em;line-height:1;color:var(--navy)}
  .dr-title .tt{font-size:22px;color:var(--navy);line-height:1.4}
  .dr-meta{
    margin-top:18px;padding:14px 18px;
    background:#fff;border-radius:3px;border:1px solid var(--cream-3);
    display:flex;align-items:center;gap:24px;
    font-family:var(--mono);font-size:12px;color:var(--navy);
    letter-spacing:.06em;
  }
  .dr-meta b{color:var(--peach-3);font-weight:600}
  .dr-text{
    margin-top:24px;padding:24px 26px;
    background:#fff;border-radius:3px;
    border-left:3px solid var(--peach);
    font-size:15.5px;line-height:1.95;color:var(--navy);
  }
  .dr-text p{margin-bottom:10px}
  .dr-text p:last-child{margin-bottom:0}
  .dr-text .ro{
    font-family:var(--mono);font-size:13px;color:var(--peach-3);
    font-weight:600;margin-right:6px;
  }
  .dr-text .hl{
    background:rgba(231,187,167,.42);
    padding:1px 4px;border-radius:2px;color:var(--navy);font-weight:600;
  }
  .dr-text .but{
    margin-top:14px;padding-top:12px;border-top:1px dashed rgba(31,56,72,.14);
    color:rgba(31,56,72,.65);font-size:14px;
  }
  .dr-text .but b{color:var(--peach-3);font-weight:600}

  /* accordion sections inside drawer */
  .dr-acc{margin-top:24px;border-top:1px solid var(--cream-3)}
  .acc-item{border-bottom:1px solid var(--cream-3)}
  .acc-head{
    display:flex;align-items:center;gap:14px;
    padding:16px 6px;cursor:pointer;
    transition:.18s;
  }
  .acc-head:hover{padding-left:12px}
  .acc-head .cv{
    font-family:var(--mono);font-size:11px;color:var(--peach-3);
    transition:transform .25s;width:14px;display:inline-block;
  }
  .acc-head .num{
    font-family:var(--mono);font-size:12px;font-weight:600;
    color:rgba(31,56,72,.45);letter-spacing:.04em;
  }
  .acc-head .ttl{
    font-family:var(--serif);font-size:16.5px;font-weight:500;
    color:rgba(31,56,72,.85);letter-spacing:.01em;
  }
  .acc-item.open .acc-head .cv{transform:rotate(90deg);color:var(--peach-3)}
  .acc-item.open .acc-head .ttl{color:var(--navy)}
  .acc-item.open .acc-head .num{color:var(--peach-3)}
  .acc-body{
    max-height:0;overflow:hidden;
    transition:max-height .3s ease;
  }
  .acc-item.open .acc-body{max-height:600px}
  .acc-inner{
    padding:4px 22px 22px 28px;
    font-size:14px;line-height:1.85;color:rgba(31,56,72,.78);
  }
  .acc-inner p{margin-bottom:8px}
  .acc-inner b{color:var(--navy);font-weight:600}
  .acc-inner .kw{
    background:rgba(231,187,167,.32);padding:1px 5px;border-radius:2px;
    color:var(--navy);font-weight:500;
  }
  .acc-empty{color:rgba(31,56,72,.45);font-style:normal;font-size:13px}

  /* chip-style top actions in drawer */
  .dr-actions{
    display:flex;gap:8px;margin-top:18px;
  }
  .dr-chip{
    flex:0 0 auto;padding:9px 18px;border-radius:3px;
    border:1px solid var(--cream-3);background:#fff;
    font-size:13px;color:rgba(31,56,72,.7);
    cursor:pointer;transition:.18s;
    display:flex;align-items:center;gap:6px;
  }
  .dr-chip:hover{border-color:var(--peach-3);color:var(--navy)}
  .dr-chip.on{background:var(--peach);color:var(--navy);border-color:var(--peach);font-weight:600}
  .dr-chip .ic{font-family:var(--mono);font-size:12px}

  .dr-foot{
    padding:18px 28px;background:var(--cream-2);
    border-top:1px solid var(--cream-3);
    display:flex;gap:10px;
  }
  .dr-btn{
    flex:1;padding:14px 18px;border-radius:3px;
    font-family:var(--sans);font-size:14px;font-weight:600;
    text-align:center;cursor:pointer;transition:.18s;
    display:flex;align-items:center;justify-content:center;gap:8px;
  }
  .dr-btn.pri{background:var(--navy);color:var(--cream)}
  .dr-btn.pri:hover{background:var(--navy-2)}
  .dr-btn.sec{background:transparent;color:var(--navy);border:1px solid var(--navy)}
  .dr-btn.sec:hover{background:rgba(31,56,72,.06)}
  .dr-btn.peach{background:var(--peach);color:var(--navy)}
  .dr-btn.peach:hover{background:var(--peach-2)}

  /* === RWD === */
  @media (max-width: 1100px){
    .shell{grid-template-columns:220px 1fr}
    main.main{padding:48px 40px 72px}
    .mc-stats{grid-template-columns:1fr 1fr}
    .card-grid,.tool-grid,.laws-grid{grid-template-columns:repeat(2,1fr)}
    .search-row{grid-template-columns:1fr 1fr}
  }
  @media (max-width: 760px){
    .topbar{padding:14px 20px}
    .top-mid{display:none}
    .menu-btn{display:flex}
    .shell{grid-template-columns:1fr}
    aside.side{
      position:fixed;top:65px;left:0;width:280px;height:calc(100vh - 65px);
      transform:translateX(-100%);transition:transform .3s;
      z-index:40;border-right:1px solid var(--line);
    }
    aside.side.open{transform:translateX(0)}
    main.main{padding:32px 20px 60px}
    .greet{flex-direction:column;align-items:flex-start;gap:18px}
    .greet h1{font-size:32px}
    .greet .now{text-align:left}
    .greet .now .t{font-size:24px}
    .member-card{grid-template-columns:1fr;padding:24px}
    .mc-r{border-left:none;border-top:1px solid var(--line-2);padding:24px 0 0;padding-left:0}
    .mc-stats{grid-template-columns:1fr 1fr}
    .prog-card{padding:24px}
    .prog-stats{grid-template-columns:1fr 1fr;gap:24px 0}
    .ps{padding:12px 14px;border-right:1px solid var(--line);border-bottom:1px solid var(--line)}
    .ps:nth-child(2n){border-right:none}
    .ps:nth-last-child(-n+2){border-bottom:none}
    .ps .v{font-size:42px}
    .prog-row{grid-template-columns:100px 1fr 34px;gap:14px}
    .prog-row .name{font-size:13px}
    .search-row{grid-template-columns:1fr}
    .card-grid,.tool-grid,.laws-grid{grid-template-columns:1fr}
    .sec-head{flex-direction:column;align-items:flex-start;gap:8px}
    .res-row,.rec-row{flex-direction:column;align-items:flex-start;gap:8px}
    .res-l,.rec-l{flex-wrap:wrap}
    .res-l .ttl,.rec-l .ttl{border-left:none;padding-left:0}
    .drawer{width:100%}
    .laws-head{flex-direction:column;align-items:flex-start;gap:12px}
    .laws-search{width:100%}
  }
</style>
</head>
<body data-screen-label="01 Dashboard">

  <!-- ============ TOP BAR ============ -->
  <header class="topbar">
    <a class="brand" href="/"><span class="dot"></span>SOFA&nbsp;ENGINE</a>
    <nav class="top-mid">
      <a href="#member">會員</a>
      <a href="#progress">進度</a>
      <a href="#search">查法條</a>
      <a href="#tools">備考工具</a>
      <a href="#laws">法規</a>
    </nav>
    <div class="top-right">
      <span class="user-pill"><span class="live"></span>Fay</span>
      <button class="btn-out">登出</button>
      <button class="menu-btn" onclick="document.querySelector('aside.side').classList.toggle('open')"><span></span></button>
    </div>
  </header>

  <div class="shell">

    <!-- ============ SIDEBAR ============ -->
    <aside class="side">
      <div class="countdown">
        <div class="cd-lab">距考試</div>
        <div class="cd-num">187</div>
        <div class="cd-unit">          天 倒數中</div>
        <div class="cd-date">
          <span>考試日</span>
          <span>2026 / 11 / 14</span>
        </div>
      </div>

      <div class="nav-section">
        <div class="lab">導覽</div>
        <div class="nav-list">
          <a href="#member" class="on"><span class="num">01</span>會員資訊</a>
          <a href="#progress"><span class="num">02</span>學習進度</a>
          <a href="#search"><span class="num">03</span>法條搜尋</a>
          <a href="#favorites"><span class="num">04</span>我的收藏</a>
          <a href="#memorized"><span class="num">05</span>已熟記</a>
          <a href="#review"><span class="num">06</span>待複習</a>
          <a href="#tools"><span class="num">07</span>備考工具</a>
          <a href="#laws"><span class="num">08</span>法規目錄</a>
          <a href="#recent"><span class="num">09</span>最近查詢</a>
        </div>
      </div>

      <div class="side-foot">
        坐下來，<br/>一條一條來。<br/>
        <b>2,138</b> 條 · <b>33</b> 部法規
        <div style="margin-top:18px;display:flex;flex-direction:column;gap:6px;">
          <a href="terms.html" style="font-family:var(--mono);font-size:11px;color:rgba(245,240,234,.35);letter-spacing:.08em;text-decoration:none;transition:.18s" onmouseover="this.style.color='rgba(245,240,234,.7)'" onmouseout="this.style.color='rgba(245,240,234,.35)'">服務聲明 / 退費政策 →</a>
          <a href="mailto:hi@sofaengine.org" style="font-family:var(--mono);font-size:11px;color:rgba(245,240,234,.35);letter-spacing:.08em;text-decoration:none;transition:.18s" onmouseover="this.style.color='rgba(245,240,234,.7)'" onmouseout="this.style.color='rgba(245,240,234,.35)'">hi@sofaengine.org</a>
          <span style="font-family:var(--mono);font-size:10px;color:rgba(245,240,234,.18);letter-spacing:.06em;margin-top:6px">v3.0.0 · 2026.05</span>
        </div>
      </div>
    </aside>

    <!-- ============ MAIN ============ -->
    <main class="main">
      <div class="main-inner">

        <!-- Greet -->
        <div class="greet">
          <div>
            <h1>晚安，<em>Fay</em>。<br/>今天讀一條也算數。</h1>
            <p class="sub">距離考試還有 187 天。本週進度 6 / 7，連續學習 3 天——坐下來繼續吧。</p>
          </div>
          <div class="now">
            <div class="l">TONIGHT · TAIPEI</div>
            <div class="t">22:48</div>
            <div class="l">2026.05.11 · 一</div>
          </div>
        </div>

        <!-- ============ 01 MEMBER ============ -->
        <section class="block" id="member">
          <div class="sec-head">
            <div class="l">
              <span class="eb">SECTION 01 — MEMBER</span>
              <h2>會員資訊</h2>
            </div>
            <div class="r">序號 · <a href="#">查看</a></div>
          </div>

          <div class="member-card">
            <div class="mc-l">
              <div class="mc-tags">
                <span class="mc-tag" id="mc-plan">月費方案</span>
                <span class="mc-status" id="mc-status">ACTIVE</span>
              </div>
              <div class="mc-divider"></div>
              <div class="mc-stats">
                <div class="mc-stat">
                  <div class="k">到期日</div>
                  <div class="v peach" id="mc-expires">—</div>
                </div>
                <div class="mc-stat">
                  <div class="k">剩餘天數</div>
                  <div class="v good" id="mc-days-left">—</div>
                </div>
                <div class="mc-stat">
                  <div class="k">啟用日</div>
                  <div class="v" id="mc-activated">—</div>
                </div>
              </div>
            </div>
            <div class="mc-r">
              <div class="avatar" id="mc-avatar">?</div>
              <div class="avatar-name" id="mc-serial-short">——</div>
            </div>
          </div>

          <!-- 付費紀錄 -->
          <div class="pay-block">
            <div class="pay-block-head">
              <span class="lab">付費紀錄</span>
              <span class="hint">序號啟用即生效 · 7 天未啟用可退費</span>
            </div>
            <table class="pay-table">
              <thead>
                <tr>
                  <th>序號</th>
                  <th>方案</th>
                  <th>啟用日</th>
                  <th>到期日</th>
                  <th>狀態</th>
                </tr>
              </thead>
              <tbody id="pay-tbody">
                <tr><td colspan="5" class="pay-empty">載入中…</td></tr>
              </tbody>
            </table>
          </div>
        </section>

        <!-- ============ 02 PROGRESS ============ -->
        <section class="block" id="progress">
          <div class="sec-head">
            <div class="l">
              <span class="eb">SECTION 02 — PROGRESS</span>
              <h2>學習進度</h2>
            </div>
            <div class="r">本週 · <a href="#">查看週報</a></div>
          </div>

          <div class="prog-card">
            <div class="prog-stats">
              <div class="ps"><div class="v">8</div><div class="k">已查條文</div></div>
              <div class="ps"><div class="v">6</div><div class="k">涵蓋法規</div></div>
              <div class="ps"><div class="v">1</div><div class="k">已收藏</div></div>
              <div class="ps"><div class="v">3</div><div class="k">連續天數</div></div>
            </div>

            <div class="prog-list">
              <div class="prog-row">
                <span class="name">記帳士法</span>
                <div class="prog-bar"><div class="fill" style="width:62%"></div></div>
                <span class="n">2</span>
              </div>
              <div class="prog-row">
                <span class="name">商業登記法</span>
                <div class="prog-bar"><div class="fill" style="width:54%"></div></div>
                <span class="n">2</span>
              </div>
              <div class="prog-row">
                <span class="name">所得稅法</span>
                <div class="prog-bar"><div class="fill" style="width:38%"></div></div>
                <span class="n">1</span>
              </div>
              <div class="prog-row">
                <span class="name">所得基本稅額條例</span>
                <div class="prog-bar"><div class="fill" style="width:32%"></div></div>
                <span class="n">1</span>
              </div>
              <div class="prog-row">
                <span class="name">所得基本稅額條例施行細則</span>
                <div class="prog-bar"><div class="fill" style="width:28%"></div></div>
                <span class="n">1</span>
              </div>
              <div class="prog-row">
                <span class="name">遺產及贈與稅法</span>
                <div class="prog-bar"><div class="fill" style="width:24%"></div></div>
                <span class="n">1</span>
              </div>
            </div>
          </div>
        </section>

        <!-- ============ 03 SEARCH ============ -->
        <section class="block" id="search">
          <div class="sec-head">
            <div class="l">
              <span class="eb">SECTION 03 — SEARCH</span>
              <h2>直接查法條</h2>
            </div>
            <div class="r">共 2,138 條 · 33 部</div>
          </div>

          <div class="search-card">
            <div class="search-row">
              <div class="field">
                <span class="ic">⌕</span>
                <input placeholder="輸入法規名稱…" />
              </div>
              <div class="field">
                <span class="ic">§</span>
                <input placeholder="搜尋條號或關鍵字…" />
              </div>
